# Copy to .env and adjust. All values have safe local-dev defaults.

ENVIRONMENT=development

# Local dev (zero infra). For production use Postgres:
# DATABASE_URL=postgresql+asyncpg://lien:lien@localhost:5432/lien
DATABASE_URL=sqlite+aiosqlite:///./lien_api.db

# Comma-separated accepted API keys. REPLACE before any real deployment.
API_KEYS=dev-key-123

RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_PAGE_SIZE=100

CORS_ALLOW_ORIGINS=*
